# EmailJS setup — https://www.emailjs.com
# 1. Create a free account and an Email Service (e.g. Gmail).
# 2. Create an Email Template with variables: full_name, phone, email, course, branch, message.
# 3. Copy the three IDs below into a real .env.local file (never commit .env.local).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
